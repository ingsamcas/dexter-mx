# LLM Provider (OpenRouter for multi-model support)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-5.2

# Data Sources
PRIMARY_DATA_SOURCE=databursatil
SECONDARY_DATA_SOURCE=yfinance
DATABURSATIL_API_KEY=your-databursatil-api-key

# Optional: Financial Datasets (paid, US market)
# FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key

# Legacy (not required if using OpenRouter)
